# =============================================================================
# KYC/KYB Onboarding Platform — Environment Variables
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores no .env com suas credenciais reais
#   3. NUNCA commite o arquivo .env no git
# =============================================================================


# ── Domínio e SSL (obrigatório em produção com Nginx + Let's Encrypt) ──────────
# Domínio público com registro A apontando para o IP do servidor
DOMAIN="app.seudominio.com.br"

# E-mail para notificações de expiração do certificado Let's Encrypt
CERTBOT_EMAIL="admin@seudominio.com.br"


# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Credenciais usadas pelo Docker Compose para criar o container do banco
POSTGRES_USER="kyc_user"
POSTGRES_PASSWORD="troque-por-uma-senha-forte"
POSTGRES_DB="kyc_kyb_db"

# String de conexão usada pelo Prisma
# Em produção (Docker Compose): host = "db" (nome do serviço)
# Em desenvolvimento local sem Docker: host = "localhost"
DATABASE_URL="postgresql://kyc_user:troque-por-uma-senha-forte@db:5432/kyc_kyb_db"


# ── AWS ────────────────────────────────────────────────────────────────────────
# Credenciais IAM — permissões necessárias:
#   s3:PutObject, s3:GetObject
#   textract:StartDocumentAnalysis, textract:GetDocumentAnalysis
AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
AWS_REGION="us-east-1"

# Nome do bucket S3 — deve ter acesso público BLOQUEADO
S3_BUCKET_NAME="meu-bucket-kyc-documentos"


# ── NextAuth.js ────────────────────────────────────────────────────────────────
# Secret para assinar tokens JWT — gere com: openssl rand -base64 32
NEXTAUTH_SECRET="cole-aqui-o-resultado-do-openssl-rand-base64-32"

# URL base da aplicação
# Desenvolvimento: http://localhost:3000
# Produção:        https://app.seudominio.com.br (definido automaticamente pelo docker-compose)
NEXTAUTH_URL="http://localhost:3000"


# ── OCR Webhook (opcional) ─────────────────────────────────────────────────────
# Se preenchido, o endpoint /api/ocr/webhook exigirá este valor
# no header "x-webhook-secret" para aceitar requisições do Textract
# Deixe vazio para desabilitar a validação (não recomendado em produção)
OCR_WEBHOOK_SECRET=""
